# ─────────────────────────────────────────────
#  cy-gauge-app — Environment Variables Example
#  Copy this file to .env and fill in your values
#  Never commit .env to version control
# ─────────────────────────────────────────────

# ── Frontend ──────────────────────────────────
# URL of the FastAPI backend (no trailing slash)
# Local dev:
VITE_API_URL=http://localhost:8000
# Production example:
# VITE_API_URL=https://your-backend.railway.app

# ── Backend ───────────────────────────────────
# Host and port for uvicorn
HOST=0.0.0.0
PORT=8000

# Allowed origins for CORS (comma-separated)
# Use * for open access (not recommended in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Production example:
# CORS_ORIGINS=https://your-frontend.vercel.app

# ── Auth ──────────────────────────────────────
# Secret API key for protecting compute endpoints
# Generate with: openssl rand -hex 32
API_SECRET_KEY=change_me_to_a_random_secret

# Enable or disable API key auth (true/false)
AUTH_ENABLED=false

# ── Rate Limiting ─────────────────────────────
# Max requests per minute per IP on compute endpoints
RATE_LIMIT_PER_MINUTE=10

# ── Simulation Limits ─────────────────────────
# Hard caps on simulation parameters to prevent abuse
MAX_GRID_SIZE=5
MAX_EIGENVALUES=30
MAX_SWEEP_STEPS=25
SIMULATION_TIMEOUT_SECONDS=30

# ── Logging ───────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Environment ───────────────────────────────
# development | production
APP_ENV=development
